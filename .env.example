# .env.example — ridhwan.dev portfolio
# Copy this file to .env and fill in the values for local development.
# Agent B maintains this file. Agent E's validate-env.mjs reads it as the canonical list.
# All vars must also be set in the Vercel dashboard (Agent C sets them in C4/C15/C16).

# Site
SITE_URL=https://ridhwan.dev

# Substack RSS feed URL (used by feedLoader at build time)
SUBSTACK_RSS_URL=https://ridhwanamin.substack.com/feed

# Resend — transactional email for contact form (Agent B: B7)
RESEND_API_KEY=re_...

# Stripe — payment integration (Agent D)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SIGNING_SECRET=whsec_...
