# .env.example — ridhwan.dev portfolio
# Copy this file to .env and fill in the values for local development.
# Agent B maintains this file. Agent E's validate-env.mjs reads it as the canonical list.
# All vars must also be set in the Vercel dashboard (Agent C sets them in C4/C15/C16).

# Site
SITE_URL=https://ridhwan.dev

# Substack RSS feed URL (used by feedLoader at build time)
SUBSTACK_RSS_URL=https://ridhwanamin.substack.com/feed

# EmailJS — transactional email for contact form (client-side SDK).
# These are PUBLIC_* so they’re inlined into the browser bundle.
# Service ID is fixed for this project; Template ID + Public Key come from the EmailJS dashboard.
PUBLIC_EMAILJS_SERVICE_ID=service_7can0am
PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
# Optional: second template that sends the submission to YOUR inbox (To Email
# set to your address in the EmailJS dashboard). Leave blank to send only the
# visitor auto-reply. Uses the same vars: {{first_name}} {{last_name}} {{user_email}} {{message}}
PUBLIC_EMAILJS_NOTIFY_TEMPLATE_ID=

# Stripe — payment integration (Agent D)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SIGNING_SECRET=whsec_...
