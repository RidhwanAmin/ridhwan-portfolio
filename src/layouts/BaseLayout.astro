---
/**
 * BaseLayout.astro — Agent A owns this file (structure).
 *                    Agent B owns the SEO block (B9).
 *
 * HTML shell for all pages. Provides:
 * - Self-hosted fonts (Inter + JetBrains Mono via @fontsource)
 * - Lenis smooth scroll (initialised once here, consumed by GSAP per-page)
 * - Astro View Transitions for page-to-page crossfade
 * - Theme (dark/light) initialisation without FOUC
 * - Global CSS import
 * - astro-seo integration (B9): SEO component replaces manual meta tags
 * - JSON-LD structured data (B9): passed via jsonLd prop
 *
 * Animation rule: only transform + opacity. All GSAP loaded per-page, not here.
 */
import { ClientRouter } from "astro:transitions";
import { SEO } from "astro-seo";
import { SITE } from "@/config";
import "@/styles/global.css";
import "@fontsource-variable/inter";
import "@fontsource-variable/sora";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/400-italic.css";

import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
// KaTeX CSS — required for rehype-katex math rendering in MDX posts
import "katex/dist/katex.min.css";

export type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  /** Pass true to suppress Nav (e.g. on /checkout/return) */
  noNav?: boolean;
  /** Pass true to suppress Footer */
  noFooter?: boolean;
  /**
   * JSON-LD structured data object — serialised to
   * <script type="application/ld+json"> in <head> (B9).
   * Pass a BlogPosting, Person, WebSite, etc. from page components.
   */
  jsonLd?: Record<string, unknown>;
};

const {
  title = SITE.title,
  description = SITE.desc,
  ogImage = `${SITE.website}/og.png`,
  canonicalURL = new URL(Astro.url.pathname, SITE.website).toString(),
  noNav = false,
  noFooter = false,
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.lang ?? "en"} dir={SITE.dir} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Sitemap autodiscovery -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- RSS autodiscovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={`${SITE.website}/rss.xml`}
    />

    <!--
      astro-seo (B9) — handles title, description, canonical, OG, and Twitter
      cards in a single component. Pages can pass overrides via props.
    -->
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title,
          type: "website",
          image: ogImage,
          url: canonicalURL,
        },
        optional: {
          description,
          siteName: SITE.title,
        },
        image: {
          alt: title,
          width: 1200,
          height: 630,
        },
      }}
      twitter={{
        card: "summary_large_image",
        title,
        description,
        image: ogImage,
        imageAlt: title,
      }}
      extend={{
        meta: [{ name: "author", content: SITE.author }],
      }}
    />

    <!--
      JSON-LD structured data (B9).
      Pages that need schema markup (BlogPosting, BreadcrumbList, etc.)
      pass a jsonLd prop. Kept in BaseLayout so it appears before first paint.
    -->
    {
      jsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }

    <!-- Page-specific head overrides (e.g. from PostLayout, CaseStudyLayout) -->
    <slot name="head" />

    <!-- Theme — must run before first paint to prevent FOUC -->
    <script is:inline>
      (function () {
        function getTheme() {
          try {
            const stored = localStorage.getItem("theme");
            if (stored === "dark" || stored === "light") return stored;
            return window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          } catch {
            return "dark";
          }
        }

        // Apply on first load
        document.documentElement.setAttribute("data-theme", getTheme());

        // Before each View Transition swap, carry the live theme onto the
        // incoming document so the hardcoded data-theme="dark" in the new
        // HTML never flashes on screen.
        document.addEventListener("astro:before-swap", function (e) {
          e.newDocument.documentElement.setAttribute(
            "data-theme",
            document.documentElement.getAttribute("data-theme") || getTheme()
          );
        });
      })();
    </script>

    <!-- Astro View Transitions — persistent nav/footer shell, page crossfade -->
    <ClientRouter />
  </head>

  <body>
    <!-- Skip-to-content for keyboard / screen reader users -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:text-white focus:outline-none"
    >
      Skip to main content
    </a>

    {!noNav && <Nav />}

    <main id="main-content">
      <slot />
    </main>

    {!noFooter && <Footer />}

    <!--
      Lenis smooth scroll — initialised once here, persists across View Transitions.
      GSAP ScrollTrigger must call `scrollerProxy` via lenis on each page.
      Disabled automatically when prefers-reduced-motion is set.
    -->
    <script>
      import Lenis from "lenis";

      function initLenis() {
        const prefersReduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        if (prefersReduced) return;

        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          touchMultiplier: 2,
        });

        // Expose on window so per-page GSAP scripts can access it
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        (window as any).__lenis = lenis;

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }

        requestAnimationFrame(raf);
      }

      // Run on first load
      initLenis();

      // Re-initialise after Astro View Transitions navigation
      document.addEventListener("astro:after-swap", () => {
        // Destroy previous instance if it exists
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        const prev = (window as any).__lenis;
        if (prev?.destroy) prev.destroy();
        initLenis();
      });
    </script>
  </body>
</html>
