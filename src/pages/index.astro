    featured: false,
    role: "Co-builder",
  },
  {
    slug: "hybrid-rag-pipeline",
    title: "Azure Hybrid RAG Pipeline",
    tagline:
      "Hybrid retrieval-augmented generation on Azure: combines dense vector search with BM25 keyword retrieval and an LLM reranker for high-precision enterprise document Q&A.",
    tags: ["Azure AI Search", "LangChain", "FAISS", "OpenAI", "FastAPI"],
    externalUrl: "https://github.com/RidhwanAmin/Azure-RAG-Hybrid",
    featured: false,
  },
];

// ── Capability data ──
const capabilities = [
  {
    variant: "llm" as const,
    headline: "LLM Engineering",
    description:
      "Designing, fine-tuning, and deploying large language models for real-world tasks. From prompt engineering and RAG pipelines to RLHF and LoRA fine-tuning on domain-specific corpora.",
    tags: ["GPT-4o", "Claude", "Llama 3", "LangChain", "RLHF", "LoRA"],
  },
  {
    variant: "genai" as const,
    headline: "Generative AI",
    description:
      "Building generative systems: diffusion models, VAEs, and multimodal pipelines. Research-grade experimentation combined with production-feasible architectures.",
    tags: ["Diffusion", "Stable Diffusion", "VAE", "ControlNet", "Fine-tuning"],
  },
  {
    variant: "python" as const,
    headline: "Python Development",
    description:
      "Fluent in the full Python ML stack. From async FastAPI services to GPU-accelerated PyTorch training loops, with clean, testable, production-ready code.",
    tags: ["PyTorch", "FastAPI", "NumPy", "Pandas", "scikit-learn", "asyncio"],
  },
  {
    variant: "cloud" as const,
    headline: "Cloud Development",
    description:
      "Deploying and scaling ML workloads on AWS and Azure. Containerised inference, managed vector stores, serverless pipelines, and IaC with Terraform.",
    tags: ["AWS", "Azure", "Docker", "Kubernetes", "Terraform", "CI/CD"],
  },
];

// ── FAQ data ──
const faqItems = [
  {
    question: "What does a typical engagement look like?",
    answer:
      "Six to twelve weeks, embedded part-time with your team. I scope a concrete deliverable up front (a deployed RAG service with evals, an agent pipeline with observability, a training and serving stack with monitoring), then ship it. Open-ended retainers are possible but I prefer shape before commitment.",
  },
  {
    question: 'How do you measure "success" on an AI project?',
    answer:
      "Evals first, vibes second. Before I touch a prompt or a model, I write a small labelled set and an eval harness that runs on every change. If I can't measure it, I won't pretend to be improving it.",
  },
  {
    question: "What stack do you reach for?",
    answer:
      "Python + FastAPI on the backend. pgvector or Qdrant for retrieval. Modal or Cloudflare Workers for serving, depending on latency budget. PyTorch when I'm training, W&B for tracking. TypeScript + Astro on the web. I'm stack-pragmatic; I'll use what your team already runs if it gets the job done.",
  },
  {
    question: "Do you handle deployment and ongoing serving?",
    answer:
      "Yes. ML that doesn't reach users isn't really ML. I set up the CI, the canary rollout, the monitoring dashboards, the alerting. I'll hand the wheel back to your team with runbooks; I won't leave you a notebook and a prayer.",
  },
  {
    question: "Available for full-time / contract / co-founding roles?",
    answer:
      "Contract-first, indefinitely. Open to interesting co-founding conversations if the problem is genuinely ML-shaped and the team has real domain context. Not looking for full-time employment right now.",
  },
];

// ── Recent writing — local MDX + Substack, newest first, top 3 ──
const localPosts = await getCollection("blog", ({ data }) => !data.draft);
// eslint-disable-next-line @typescript-eslint/no-explicit-any
let substackPosts: any[] = [];
try {
  substackPosts = await getCollection("substackPosts");
} catch {
  // Feed unreachable at build time — render local posts only.
}

type WritingItem = {
  title: string;
  href: string;
  excerpt: string;
  date: Date;
  source: "Post" | "Substack";
  external: boolean;
  tags: string[];
};

const writing: WritingItem[] = [
  ...localPosts.map(e => ({
    title: e.data.title,
    href: `/blog/${e.id}`,
    excerpt: e.data.description,
    date: new Date(e.data.pubDatetime),
    source: "Post" as const,
    external: false,
    tags: e.data.tags ?? [],
  })),
  ...substackPosts.map(e => ({
    title: (e.data.title as string) ?? "Untitled",
    href: (e.data.link as string) ?? (e.data.url as string) ?? "#",
    excerpt: (e.data.description as string) ?? (e.data.summary as string) ?? "",
    date: new Date(e.data.published ?? e.data.pubDate ?? 0),
    source: "Substack" as const,
    external: true,
    tags: [] as string[],
  })),
]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(d);

/** Strip HTML (Substack summaries are HTML), normalise dashes to commas to keep
 *  the no-em-dash voice, and trim to a clean excerpt. */
const cleanExcerpt = (s: string, max = 160) => {
  const t = s
    .replace(/<[^>]*>/g, "")
    .replace(/\s*[—–]\s*/g, ", ")
    .replace(/\s+/g, " ")
    .trim();
  if (t.length <= max) return t;
  return t.slice(0, t.lastIndexOf(" ", max)).trimEnd() + "…";
};
---

<BaseLayout>
  <!-- 1. Hero (A6) -->
  <Hero />

  <!-- 2. Capabilities -->
  <section
    id="capabilities"
    class="py-24"
    aria-labelledby="capabilities-heading"
    data-reveal="section"
  >
    <div class="app-layout">
      <div class="mb-10 flex flex-col gap-2" data-reveal="fade-up">
        <span class="font-mono text-sm text-[var(--color-text-secondary)]">
          <span class="opacity-50">//</span> capabilities
        </span>
        <h2
          id="capabilities-heading"
          class="font-display text-3xl font-bold tracking-tight text-balance text-[var(--color-text-primary)] sm:text-4xl"
        >
          What I build
        </h2>
      </div>

      <div class="grid gap-5 sm:grid-cols-2" data-reveal="stagger">
        {
          capabilities.map(cap => (
            <CapabilityCard
              variant={cap.variant}
              headline={cap.headline}
              description={cap.description}
              tags={cap.tags}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3. Featured Projects -->
  <section
    id="projects"
    class="py-24"
    aria-labelledby="projects-heading"
    data-reveal="section"
  >
    <div class="app-layout">
      <div
        class="mb-10 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
        data-reveal="fade-up"
      >
        <div class="flex flex-col gap-2">
          <span class="font-mono text-sm text-[var(--color-text-secondary)]">
            <span class="opacity-50">//</span> projects
          </span>
          <h2
            id="projects-heading"
            class="font-display text-3xl font-bold tracking-tight text-balance text-[var(--color-text-primary)] sm:text-4xl"
          >
            Featured work
          </h2>
        </div>
      </div>

      <FeaturedWorkDeck projects={featuredProjects} />
    </div>
  </section>

  <!-- 4. Writing -->
  <section
    id="writing"
    class="py-24"
    aria-labelledby="writing-heading"
    data-reveal="section"
  >
    <div class="app-layout">
      <div
        class="mb-10 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
        data-reveal="fade-up"
      >
        <div class="flex flex-col gap-2">
          <span class="font-mono text-sm text-[var(--color-text-secondary)]">
            <span class="opacity-50">//</span> blog
          </span>
          <h2
            id="writing-heading"
            class="font-display text-3xl font-bold tracking-tight text-balance text-[var(--color-text-primary)] sm:text-4xl"
          >
            Writing
          </h2>
        </div>
        <a
          href="/blog"
          class="group inline-flex items-center gap-1.5 self-start font-mono text-sm text-[var(--color-text-secondary)] transition-colors duration-150 hover:text-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-text-primary)] sm:self-auto"
        >
          All posts
          <Icon
            name="lucide:arrow-right"
            class="h-4 w-4 transition-transform duration-150 group-hover:translate-x-0.5"
            aria-hidden="true"
          />
        </a>
      </div>

      {
        writing.length > 0 ? (
          <ul class="flex flex-col" data-reveal="stagger">
            {writing.map(item => (
              <li>
                <a
                  href={item.href}
                  {...(item.external
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                  class="group grid gap-y-2 border-t border-[var(--color-border)] py-6 transition-colors duration-150 hover:border-[var(--color-border-strong)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-text-primary)] sm:grid-cols-[11rem_1fr] sm:gap-x-8"
                  aria-label={`${item.external ? "Read on Substack" : "Read post"}: ${item.title}`}
                >
                  <div class="flex items-center gap-2 font-mono text-xs text-[var(--color-text-secondary)] sm:flex-col sm:items-start sm:gap-1.5 sm:pt-1">
                    <time datetime={item.date.toISOString()}>
                      {fmtDate(item.date)}
                    </time>
                    <span class="opacity-40 sm:hidden" aria-hidden="true">
                      ·
                    </span>
                    <span class="tracking-[0.18em] uppercase">
                      {item.source}
                    </span>
                  </div>

                  <div class="flex flex-col gap-2">
                    <h3 class="flex items-start gap-2 text-lg leading-snug font-semibold text-[var(--color-text-primary)]">
                      <span class="text-pretty">{item.title}</span>
                      <Icon
                        name={
                          item.external
                            ? "lucide:arrow-up-right"
                            : "lucide:arrow-right"
                        }
                        class="mt-1 h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-all duration-150 group-hover:translate-x-0.5 group-hover:text-[var(--color-text-primary)]"
                        aria-hidden="true"
                      />
                    </h3>

                    {item.excerpt && (
                      <p class="line-clamp-2 max-w-[68ch] text-sm leading-relaxed text-[var(--color-text-secondary)]">
                        {cleanExcerpt(item.excerpt)}
                      </p>
                    )}

                    {item.tags.length > 0 && (
                      <div class="mt-1 flex flex-wrap gap-1.5">
                        {item.tags.slice(0, 4).map(tag => (
                          <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 font-mono text-[0.65rem] text-[var(--color-text-secondary)]">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <div
            class="border-t border-[var(--color-border)] py-10"
            data-reveal="fade-up"
          >
            <p class="max-w-[60ch] text-[var(--color-text-secondary)]">
              New essays are in progress. Follow along on{" "}
              <a
                href="https://ridhwanamin.substack.com"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[var(--color-text-primary)] underline decoration-dashed underline-offset-4 hover:decoration-solid"
              >
                Substack
              </a>{" "}
              for the first ones.
            </p>
          </div>
        )
      }
    </div>
  </section>

  <!-- 5. FAQ -->
  <section
    id="faq"
    class="py-24"
    aria-labelledby="faq-heading"
    data-reveal="section"
  >
    <div class="app-layout">
      <div class="mb-10 flex flex-col gap-2" data-reveal="fade-up">
        <span class="font-mono text-sm text-[var(--color-text-secondary)]">
          <span class="opacity-50">//</span> faq
        </span>
        <h2
          id="faq-heading"
          class="font-display text-3xl font-bold tracking-tight text-balance text-[var(--color-text-primary)] sm:text-4xl"
        >
          Frequently asked
        </h2>
      </div>

      <div class="max-w-2xl" data-reveal="fade-up">
        <FaqAccordion items={faqItems} headingId="faq-heading" />
      </div>
    </div>
  </section>

  <!-- 6. Contact — page closer (the conversion moment ends the page) -->
  <ContactSection />
</BaseLayout>

<script>
  /**
   * Scroll reveal — robust by design.
   *
   *   [data-reveal="fade-up"]  : single element fades up when scrolled into view
   *   [data-reveal="stagger"]  : direct children fade up in sequence
   *   [data-reveal="section"]  : wrapper marker only
   *
   * Content is VISIBLE BY DEFAULT (see global.css). We only opt the page into the
   * hidden-then-revealed states by adding `.js-reveal` once this script runs, so a
   * JS failure / slow load / headless render never ships blank sections. An
   * IntersectionObserver adds `.is-visible`; a timeout reveals anything it misses.
   * Reduced motion: we never add `.js-reveal`, so everything stays visible.
   */
  function initScrollReveal() {
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const fadeEls = Array.from(
      document.querySelectorAll<HTMLElement>('[data-reveal="fade-up"]')
    );
    const staggerKids: HTMLElement[] = [];
    document
      .querySelectorAll<HTMLElement>('[data-reveal="stagger"]')
      .forEach(container => {
        Array.from(container.children).forEach((kid, i) => {
          (kid as HTMLElement).style.setProperty("--reveal-i", String(i));
          staggerKids.push(kid as HTMLElement);
        });
      });
    const all = [...fadeEls, ...staggerKids];
    if (all.length === 0 || reduce) return;

    // Opt in to the hidden state only now that JS is confirmed running.
    document.documentElement.classList.add("js-reveal");
    const reveal = (el: Element) => el.classList.add("is-visible");

    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            reveal(entry.target);
            obs.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
    );
    all.forEach(el => io.observe(el));

    // Safety net: reveal anything still hidden after 1.6s (paused tab, headless
    // renderer, or an observer edge case) so content can never stay invisible.
    window.setTimeout(() => all.forEach(reveal), 1600);

    // Hero entrance runs on load (not scroll), so it always completes; if GSAP is
    // unavailable the hero is visible by default.
    void (async () => {
      try {
        const { gsap } = await import("gsap");
        const heroSequence = [
          { sel: ".hero-meta", y: 0, delay: 0.05 },
          { sel: "#hero-headline", y: 20, delay: 0.18 },
          { sel: ".hero-rule", y: 0, delay: 0.38 },
          { sel: "#hero-desc", y: 16, delay: 0.48 },
          { sel: "#hero-ctas", y: 16, delay: 0.62 },
        ];
        heroSequence.forEach(({ sel, y, delay }) => {
          const el = document.querySelector(sel);
          if (el) {
            gsap.from(el, {
              opacity: 0,
              y,
              duration: 0.7,
              ease: "power3.out",
              delay,
            });
          }
        });
      } catch {
        /* GSAP unavailable — hero stays visible. */
      }
    })();
  }

  initScrollReveal();
  document.addEventListener("astro:after-swap", initScrollReveal);
</script>
