<script>
  /**
   * A15 — ScrollReveal using GSAP ScrollTrigger.
   *
   * Reveal types via data attributes:
   *   [data-reveal="fade-up"]   — single element fade up
   *   [data-reveal="stagger"]   — staggers direct children
   *   [data-reveal="section"]   — wrapper only; children handle themselves
   *   [data-timeline-item]      — timeline entries staggered left/right
   *
   * prefers-reduced-motion: all items rendered fully visible, no GSAP.
   * GSAP is dynamically imported to avoid blocking first paint.
   */
  async function initScrollReveal() {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (prefersReduced) {
      document
        .querySelectorAll<HTMLElement>(
          "[data-reveal='fade-up'], [data-reveal='stagger'] > *, [data-timeline-item]"
        )
        .forEach(el => {
          el.style.opacity = "1";
          el.style.transform = "none";
        });
      return;
    }

    const { gsap } = await import("gsap");
    const { ScrollTrigger } = await import("gsap/ScrollTrigger");
    gsap.registerPlugin(ScrollTrigger);

    // Sync GSAP ScrollTrigger with Lenis
    const lenis = (
      window as {
        __lenis?: {
          on: (e: string, cb: () => void) => void;
          raf: (t: number) => void;
        };
      }
    ).__lenis;
    if (lenis) {
      lenis.on("scroll", ScrollTrigger.update);
      gsap.ticker.add(time => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);
    }

    // fade-up: individual elements
    document
      .querySelectorAll<HTMLElement>("[data-reveal='fade-up']")
      .forEach(el => {
        gsap.from(el, {
          opacity: 0,
          y: 24,
          duration: 0.7,
          ease: "power2.out",
          scrollTrigger: {
            trigger: el,
            start: "top 88%",
            once: true,
          },
        });
      });

    // stagger: direct children of [data-reveal="stagger"]
    document
      .querySelectorAll<HTMLElement>("[data-reveal='stagger']")
      .forEach(container => {
        const children = Array.from(container.children) as HTMLElement[];
        gsap.from(children, {
          opacity: 0,
          y: 28,
          duration: 0.6,
          ease: "power2.out",
          stagger: 0.1,
          scrollTrigger: {
            trigger: container,
            start: "top 85%",
            once: true,
          },
        });
      });

    // Timeline items: alternating left/right slide-in
    const timelineContainer = document.querySelector<HTMLElement>(
      "[data-reveal='timeline']"
    );
    if (timelineContainer) {
      timelineContainer
        .querySelectorAll<HTMLElement>("[data-timeline-item]")
        .forEach((item, i) => {
          gsap.from(item, {
            opacity: 0,
            x: i % 2 === 0 ? -24 : 24,
            duration: 0.65,
            ease: "power2.out",
            delay: i * 0.08,
            scrollTrigger: {
              trigger: item,
              start: "top 88%",
              once: true,
            },
          });
        });
    }
  }

  initScrollReveal();
  document.addEventListener("astro:after-swap", initScrollReveal);
</script>
