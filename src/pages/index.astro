---
/**
 * index.astro — home page.
 *
 * Sections (About removed by request):
 *   1. Hero          : Interpolation Field canvas + intro
 *   2. Capabilities  : animated monochrome capability cards
 *   3. Featured work : auto-marquee project deck
 *   4. Writing       : recent local + Substack posts (hairline list)
 *   5. FAQ           : accordion
 *   6. Contact       : form + scheduling + services CTA (page closer)
 *
 * Section headers use the "// label" mono cadence (the engineer's-annotation
 * brand voice), not numbered eyebrows. ScrollReveal is wired in the script
 * block at the bottom.
 */
export const prerender = true;

import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import FeaturedWorkDeck from "@/components/FeaturedWorkDeck.astro";
import CapabilityCard from "@/components/CapabilityCard.astro";

import FaqAccordion from "@/components/FaqAccordion.astro";
import ContactSection from "@/components/ContactSection.astro";

// ── Featured projects data ──
// First two are live products with screenshot previews.
// Last two are ML/research projects (plain research-log cards).
const featuredProjects = [
  {
    slug: "malaysia-hospital-bed-explorer",
    title: "Malaysia Hospital Bed Explorer",
    tagline:
      "Real-time dashboard surfacing available hospital beds across every Malaysian state, built on Cloudflare Workers and the Ministry of Health open-data API.",
    tags: ["Cloudflare Workers", "React", "MOH Open Data", "REST API"],
    thumbnail: "/images/projects/hospital-beds-explorer.png",
    thumbnailAlt:
      "Hospital Bed Explorer homepage showing a map and real-time bed availability across Malaysia",
    externalUrl: "https://malaysia-hospital-bed.ridhwanamin97.workers.dev/",
    featured: true,
  },
  {
    slug: "stethoz",
    title: "Stethoz: Professional Network for Healthcare",
    tagline:
      "Co-built a LinkedIn-style networking platform for doctors, nurses, and allied health professionals to share clinical knowledge, discuss cases, and discover locum opportunities.",
    tags: ["Healthcare Tech", "Social Platform", "Malaysia", "Made in MY 🇲🇾"],
    thumbnail: "/images/projects/stethoz.png",
    thumbnailAlt:
      "Stethoz homepage showing the professional network for healthcare workers with a countdown to launch",
    externalUrl: "https://stethoz.com/",
    featured: false,
    role: "Co-builder",
  },
  {
    slug: "redoai-solutions",
    title: "REDO AI Solutions",
    tagline:
      "AI consultation and cloud training platform helping organisations accelerate digital transformation through hands-on programmes and expert guidance.",
    tags: ["AI Education", "Cloud Training", "Consultation"],
