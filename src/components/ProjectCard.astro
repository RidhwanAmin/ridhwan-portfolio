---
/**
 * ProjectCard.astro — Agent A owns this file. Task A7.
 *
 * Horizontal "research log entry" card layout.
 * Left: teal accent border + bold index number.
 * Right: title, tagline, tech pills, hover arrow.
 *
 * Props are aligned with the case-studies content collection schema.
 */
import { Icon } from "astro-icon/components";

export interface Props {
  /** URL slug — used to build /projects/[slug] */
  slug: string;
  /** Project title */
  title: string;
  /** One-sentence description */
  tagline: string;
  /** Tech tags to display as pills */
  tags?: string[];
  /** Optional hero/thumbnail image URL (kept for API compatibility, not rendered) */
  thumbnail?: string;
  /** Alt text for the thumbnail */
  thumbnailAlt?: string;
  /** Optional: highlight this card as featured */
  featured?: boolean;
  /** Display index for research log numbering (01, 02, 03...) */
  index?: number;
}

const {
  slug,
  title,
  tagline,
  tags = [],
  featured = false,
  index,
} = Astro.props;

const href = `/projects/${slug}`;
const displayIndex =
  index !== undefined ? String(index).padStart(2, "0") : undefined;
---

<article
  class:list={[
    "project-card group relative flex overflow-hidden rounded-lg",
    "border border-[var(--color-border)] border-l-[3px] border-l-[var(--color-teal)] bg-[var(--color-surface)]",
    "transition-all duration-300",
    "hover:border-[var(--color-teal)] hover:bg-[var(--color-surface-hover)]",
    featured &&
      "ring-1 ring-[var(--color-teal)] ring-offset-2 ring-offset-[var(--color-bg)]",
  ]}
>
  <!-- Index column -->
  {
    displayIndex && (
      <div
        class="flex shrink-0 items-start justify-center w-14 pt-5"
        aria-hidden="true"
      >
        <span class="card-index font-mono text-xl font-bold text-[var(--color-teal)] opacity-50 transition-opacity duration-200 group-hover:opacity-100">
          {displayIndex}
        </span>
      </div>
    )
  }

  <!-- Content -->
  <div class="flex flex-1 flex-col gap-2.5 px-5 py-5">
    {
      featured && (
        <span class="inline-flex w-fit items-center gap-1 rounded-full bg-[var(--color-teal-muted)] px-2.5 py-0.5 text-xs font-medium text-[var(--color-teal)]">
          <Icon name="lucide:star" class="h-3 w-3" aria-hidden="true" />
          Featured
        </span>
      )
    }

    <h3
      class="text-base leading-snug font-semibold text-[var(--color-text-primary)] transition-colors duration-150 group-hover:text-[var(--color-teal)]"
    >
      <a
        href={href}
        aria-label={`View case study: ${title}`}
        class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
      >
        {title}
      </a>
    </h3>

    <p class="text-sm leading-relaxed text-[var(--color-text-secondary)]">
      {tagline}
    </p>

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5" role="list" aria-label="Technologies used">
          {tags.map(tag => (
            <span
              role="listitem"
              class="rounded border border-[var(--color-border)] bg-[var(--color-bg)] px-2 py-0.5 font-mono text-[0.6rem] text-[var(--color-text-muted)]"
            >
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>

  <!-- Hover arrow: slides in from left on hover -->
  <div
    class="card-arrow flex items-center justify-center w-10 pr-4 opacity-0 -translate-x-2 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0"
    aria-hidden="true"
  >
    <Icon
      name="lucide:arrow-right"
      class="h-4 w-4 text-[var(--color-teal)]"
      aria-hidden="true"
    />
  </div>
</article>

<style>
  @media (prefers-reduced-motion: reduce) {
    .card-arrow {
      transition: none;
      opacity: 1;
      transform: none;
    }
    .card-index {
      transition: none;
    }
  }
</style>
