---
/**
 * CapabilityCard.astro — Animated skill cards.
 *
 * Each variant has a unique steadily-animated visual zone:
 *   llm    — three horizontal token streams scrolling at different speeds
 *   genai  — colour blobs orbiting slowly (generative art feel)
 *   python — Python code scrolling upward, syntax-highlighted
 *   cloud  — SVG node graph with animated data packets
 *
 * Animations respect prefers-reduced-motion.
 */

export interface Props {
  variant: "llm" | "genai" | "python" | "cloud";
  headline: string;
  description: string;
  tags?: string[];
}

const { variant, headline, description, tags = [] } = Astro.props;

// Token lists — each appears twice in the DOM for seamless infinite scroll
const llmRow1 = ["system","prompt","temperature","context window","fine-tune","RLHF","tokenizer","beam search","top-p","chain-of-thought"];
const llmRow2 = ["⟨input⟩","→","attention","→","embedding","→","logit","→","sample","→","⟨output⟩","→"];
const llmRow3 = ["GPT-4o","Claude 3","Llama 3","Mistral","Gemini","LoRA","QLoRA","RAG","ORPO","SFT"];

// Python code lines — duplicated for seamless scroll
const codeLines = [
  { t: "kw", v: "import" },    { t: "id", v: " torch" },
  { t: "kw", v: "from" },      { t: "id", v: " transformers " }, { t: "kw", v: "import" }, { t: "id", v: " AutoModel" },
  { t: "blank", v: "" },
  { t: "kw", v: "class" },     { t: "fn", v: " RAGPipeline" }, { t: "id", v: ":" },
  { t: "kw", v: "  def" },     { t: "fn", v: " __init__" }, { t: "id", v: "(self, model_id):" },
  { t: "id", v: "    self.model " }, { t: "op", v: "=" }, { t: "id", v: " AutoModel" },
  { t: "id", v: "      .from_pretrained(model_id)" },
  { t: "blank", v: "" },
  { t: "kw", v: "  def" },     { t: "fn", v: " encode" }, { t: "id", v: "(self, text):" },
  { t: "id", v: "    tokens " }, { t: "op", v: "=" }, { t: "id", v: " self.tokenizer(text)" },
  { t: "kw", v: "    with" },  { t: "id", v: " torch.no_grad():" },
  { t: "kw", v: "      return" }, { t: "id", v: " self.model(**tokens)" },
  { t: "blank", v: "" },
  { t: "kw", v: "def" },       { t: "fn", v: " hybrid_search" }, { t: "id", v: "(query, k" }, { t: "op", v: "=" }, { t: "num", v: "5" }, { t: "id", v: "):" },
  { t: "id", v: "    dense " }, { t: "op", v: "=" }, { t: "id", v: " faiss_index.search(query, k)" },
  { t: "id", v: "    sparse " }, { t: "op", v: "=" }, { t: "id", v: " bm25.get_top_n(query, k)" },
  { t: "kw", v: "    return" }, { t: "id", v: " rerank(dense " }, { t: "op", v: "+" }, { t: "id", v: " sparse)" },
  { t: "blank", v: "" },
  { t: "kw", v: "async def" }, { t: "fn", v: " stream_response" }, { t: "id", v: "(prompt: str):" },
  { t: "kw", v: "    async for" }, { t: "id", v: " chunk " }, { t: "kw", v: "in" }, { t: "id", v: " llm.astream(prompt):" },
  { t: "kw", v: "      yield" }, { t: "id", v: " chunk.content" },
];
---

<article class={`cap-card cap-card--${variant} group relative overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] transition-all duration-500 hover:border-[var(--color-border-strong)]`}>

  <!-- ═══════════════════════════ VISUAL ZONE ═══════════════════════════ -->
  <div class="visual-zone relative overflow-hidden" style="height:168px; background:#050508;" aria-hidden="true">

    <!-- ── LLM: Three scrolling token streams ── -->
    {variant === "llm" && (
      <div class="llm-stage absolute inset-0 flex flex-col justify-center gap-3 py-4">
        <!-- Row 1: scrolls left, dim -->
        <div class="stream overflow-hidden">
          <div class="reel reel-1 flex gap-2 whitespace-nowrap">
            {[...llmRow1, ...llmRow1].map(w => (
              <span class="token-pill dim">{w}</span>
            ))}
          </div>
        </div>
        <!-- Row 2: scrolls right (reverse), bright + accent arrow -->
        <div class="stream overflow-hidden">
          <div class="reel reel-2 flex gap-2 whitespace-nowrap">
            {[...llmRow2, ...llmRow2].map((w, i) => (
              <span class={`token-pill ${w === "→" ? "arrow" : i % 5 === 0 ? "bright" : ""}`}>{w}</span>
            ))}
          </div>
        </div>
        <!-- Row 3: scrolls left, faster, muted -->
        <div class="stream overflow-hidden">
          <div class="reel reel-3 flex gap-2 whitespace-nowrap">
            {[...llmRow3, ...llmRow3].map(w => (
              <span class="token-pill model">{w}</span>
            ))}
          </div>
        </div>
        <!-- Fade edges -->
        <div class="pointer-events-none absolute inset-y-0 left-0 w-16" style="background:linear-gradient(to right,#050508,transparent);" />
        <div class="pointer-events-none absolute inset-y-0 right-0 w-16" style="background:linear-gradient(to left,#050508,transparent);" />
      </div>
    )}

    <!-- ── Generative AI: Floating colour orbs ── -->
    {variant === "genai" && (
      <div class="genai-stage absolute inset-0">
        <!-- Dot-grid background -->
        <div class="dot-grid absolute inset-0" />
        <!-- Orbs -->
        <div class="orb orb-amber" />
        <div class="orb orb-violet" />
        <div class="orb orb-cyan" />
        <div class="orb orb-white" />
        <!-- Centre label -->
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="genai-label font-mono text-[0.55rem] tracking-[0.2em] text-white/30 uppercase select-none">
            generative · diffusion · synthesis
          </div>
        </div>
      </div>
    )}

    <!-- ── Python: Scrolling syntax-highlighted code ── -->
    {variant === "python" && (
      <div class="py-stage absolute inset-0 overflow-hidden px-5 py-3">
        <!-- Two copies stacked for infinite scroll -->
        <div class="py-scroll font-mono text-[0.6rem] leading-[1.7] select-none">
          {[...codeLines, ...codeLines].map((token) => (
            token.t === "blank"
              ? <div class="py-blank" />
              : token.t === "kw"   ? <span class="py-kw">{token.v}</span>
              : token.t === "fn"   ? <span class="py-fn">{token.v}</span>
              : token.t === "str"  ? <span class="py-str">{token.v}</span>
              : token.t === "num"  ? <span class="py-num">{token.v}</span>
              : token.t === "op"   ? <span class="py-op">{token.v}</span>
              : <span class="py-id">{token.v}</span>
          ))}
        </div>
        <!-- Top / bottom fade -->
        <div class="pointer-events-none absolute inset-x-0 top-0 h-10" style="background:linear-gradient(to bottom,#050508,transparent);" />
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-10" style="background:linear-gradient(to top,#050508,transparent);" />
      </div>
    )}

    <!-- ── Cloud: SVG node graph with travelling packets ── -->
    {variant === "cloud" && (
      <div class="cloud-stage absolute inset-0">
        <svg viewBox="0 0 320 168" class="w-full h-full" fill="none">
          <!-- Connection lines -->
          <g class="connections" stroke="rgba(255,255,255,0.1)" stroke-width="1" stroke-dasharray="3 4">
            <line x1="70" y1="42" x2="160" y2="88" />   <!-- aws → hub -->
            <line x1="250" y1="42" x2="160" y2="88" />  <!-- azure → hub -->
            <line x1="160" y1="88" x2="70" y2="134" />  <!-- hub → docker -->
            <line x1="160" y1="88" x2="160" y2="144" /> <!-- hub → k8s -->
            <line x1="160" y1="88" x2="250" y2="134" /> <!-- hub → tf -->
            <line x1="70" y1="42" x2="250" y2="42" />   <!-- aws → azure -->
          </g>

          <!-- Animated packets (bright dots travelling along each line) — monochrome -->
          <!-- Packet: AWS → Hub -->
          <line class="pkt pkt-1" x1="70" y1="42" x2="160" y2="88"
            stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"
            stroke-dasharray="4 200" />
          <!-- Packet: Azure → Hub -->
          <line class="pkt pkt-2" x1="250" y1="42" x2="160" y2="88"
            stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"
            stroke-dasharray="4 200" />
          <!-- Packet: Hub → Docker -->
          <line class="pkt pkt-3" x1="160" y1="88" x2="70" y2="134"
            stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"
            stroke-dasharray="4 200" />
          <!-- Packet: Hub → K8s -->
          <line class="pkt pkt-4" x1="160" y1="88" x2="160" y2="144"
            stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"
            stroke-dasharray="4 200" />
          <!-- Packet: Hub → Terraform -->
          <line class="pkt pkt-5" x1="160" y1="88" x2="250" y2="134"
            stroke="#ffffff" stroke-width="2.5" stroke-linecap="round"
            stroke-dasharray="4 200" />
          <!-- Packet: AWS ↔ Azure -->
          <line class="pkt pkt-6" x1="70" y1="42" x2="250" y2="42"
            stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"
            stroke-dasharray="4 200" />

          <!-- Pulse rings on hub -->
          <circle class="hub-ring ring-1" cx="160" cy="88" r="12" stroke="rgba(255,255,255,0.15)" stroke-width="1" fill="none" />
          <circle class="hub-ring ring-2" cx="160" cy="88" r="20" stroke="rgba(255,255,255,0.07)" stroke-width="1" fill="none" />

          <!-- Hub node -->
          <circle cx="160" cy="88" r="7" fill="#ffffff" />

          <!-- Leaf nodes — monochrome: hairline ring + grey label -->
          <!-- AWS -->
          <circle cx="70" cy="42" r="14" fill="#050508" stroke="rgba(255,255,255,0.45)" stroke-width="1.5" />
          <text x="70" y="46" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="7" font-family="monospace" font-weight="700">AWS</text>
          <!-- Azure -->
          <circle cx="250" cy="42" r="14" fill="#050508" stroke="rgba(255,255,255,0.45)" stroke-width="1.5" />
          <text x="250" y="46" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-size="7" font-family="monospace" font-weight="700">AZ</text>
          <!-- Docker -->
          <circle cx="70" cy="134" r="12" fill="#050508" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" />
          <text x="70" y="138" text-anchor="middle" fill="rgba(255,255,255,0.65)" font-size="6" font-family="monospace">DOCK</text>
          <!-- K8s -->
          <circle cx="160" cy="144" r="12" fill="#050508" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" />
          <text x="160" y="148" text-anchor="middle" fill="rgba(255,255,255,0.65)" font-size="6" font-family="monospace">K8S</text>
          <!-- Terraform -->
          <circle cx="250" cy="134" r="12" fill="#050508" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" />
          <text x="250" y="138" text-anchor="middle" fill="rgba(255,255,255,0.65)" font-size="6" font-family="monospace">TF</text>
        </svg>
      </div>
    )}

    <!-- Shared: bottom fade into card surface -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-8"
      style="background:linear-gradient(to top,var(--color-surface),transparent);" aria-hidden="true" />
  </div>

  <!-- ═══════════════════════════ CONTENT ZONE ═══════════════════════════ -->
  <div class="p-5 pt-4">
    <h3 class="mb-1.5 text-sm font-semibold tracking-tight text-[var(--color-text-primary)]">
      {headline}
    </h3>
    <p class="mb-3 text-xs leading-relaxed text-[var(--color-text-secondary)]">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5" role="list" aria-label={`Technologies for ${headline}`}>
        {tags.map(tag => (
          <span role="listitem"
            class="rounded border border-[var(--color-border)] bg-[var(--color-bg)] px-2 py-0.5 font-mono text-[0.58rem] text-[var(--color-text-muted)]">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</article>

<style>
/* ─────────────────── LLM STREAMS ─────────────────── */
.token-pill {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 9999px;
  border: 1px solid rgba(255,255,255,0.10);
  font-family: var(--font-mono, monospace);
  font-size: 0.58rem;
  letter-spacing: 0.02em;
  color: rgba(255,255,255,0.28);
  background: rgba(255,255,255,0.03);
  white-space: nowrap;
  flex-shrink: 0;
}
.token-pill.bright  { color: rgba(255,255,255,0.85); border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.06); }
.token-pill.dim     { color: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.05); }
.token-pill.arrow   { color: rgba(255,255,255,0.5); border-color: transparent; background: transparent; font-size: 0.75rem; padding: 0 4px; }
.token-pill.model   { color: rgba(255,255,255,0.45); border-color: rgba(255,255,255,0.12); background: rgba(255,255,255,0.04); }

@media (prefers-reduced-motion: no-preference) {
  .reel-1 { animation: scroll-l 22s linear infinite; }
  .reel-2 { animation: scroll-r 16s linear infinite; }
  .reel-3 { animation: scroll-l 13s linear infinite; }
}
@keyframes scroll-l { to { transform: translateX(-50%); } }
@keyframes scroll-r { to { transform: translateX(50%); } }

/* ─────────────────── GENERATIVE AI ORBS ─────────────────── */
.dot-grid {
  background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px);
  background-size: 18px 18px;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(28px);
  will-change: transform;
}
/* Zero-Hue: orbs are white at varying opacity; depth via blur + overlap only. */
.orb-amber  { width: 110px; height: 110px; top: -20px; left: 10px;  background: rgba(255,255,255,0.16); }
.orb-violet { width: 90px;  height: 90px;  top: 30px;  right: 20px; background: rgba(255,255,255,0.12); }
.orb-cyan   { width: 70px;  height: 70px;  bottom: 0;  left: 40%;   background: rgba(255,255,255,0.09); }
.orb-white  { width: 140px; height: 140px; top: 20px;  left: 30%;   background: rgba(255,255,255,0.05); }

@media (prefers-reduced-motion: no-preference) {
  .orb-amber  { animation: float-a 9s  ease-in-out infinite; }
  .orb-violet { animation: float-b 7s  ease-in-out infinite; }
  .orb-cyan   { animation: float-c 11s ease-in-out infinite; }
  .orb-white  { animation: float-d 13s ease-in-out infinite; }
}
@keyframes float-a {
  0%,100% { transform: translate(0,0)   scale(1); }
  33%     { transform: translate(18px,-12px) scale(1.06); }
  66%     { transform: translate(-8px, 14px) scale(0.95); }
}
@keyframes float-b {
  0%,100% { transform: translate(0,0)  scale(1); }
  50%     { transform: translate(-22px,10px) scale(1.1); }
}
@keyframes float-c {
  0%,100% { transform: translate(0,0)   scale(1); }
  40%     { transform: translate(14px,-18px) scale(1.05); }
  80%     { transform: translate(-10px,8px)  scale(0.93); }
}
@keyframes float-d {
  0%,100% { transform: scale(1);    opacity: 0.5; }
  50%     { transform: scale(1.12); opacity: 0.8; }
}

/* ─────────────────── PYTHON CODE SCROLL ─────────────────── */
.py-scroll {
  display: flex;
  flex-direction: column;
  will-change: transform;
}

@media (prefers-reduced-motion: no-preference) {
  .py-scroll { animation: scroll-up 24s linear infinite; }
}
@keyframes scroll-up { to { transform: translateY(-50%); } }

/* Blank line spacer */
.py-blank { display: block; height: 0.6em; width: 100%; }

/* Zero-Hue: monochrome syntax — differentiate by weight + opacity, not color */
.py-kw  { color: rgba(255,255,255,0.92); font-weight: 600; } /* keyword */
.py-fn  { color: rgba(255,255,255,0.72); }                  /* function */
.py-str { color: rgba(255,255,255,0.45); }                  /* string */
.py-num { color: rgba(255,255,255,0.60); }                  /* number */
.py-op  { color: rgba(255,255,255,0.40); }                  /* operator */
.py-id  { color: rgba(255,255,255,0.62); }                  /* identifier */

/* ─────────────────── CLOUD GRAPH ─────────────────── */

/* Hub pulse rings */
@media (prefers-reduced-motion: no-preference) {
  .ring-1 { animation: ring-pulse 2.4s ease-out infinite; }
  .ring-2 { animation: ring-pulse 2.4s ease-out infinite 0.8s; }
}
@keyframes ring-pulse {
  0%   { transform-origin: 160px 88px; transform: scale(1); opacity: 0.8; }
  100% { transform-origin: 160px 88px; transform: scale(2.2); opacity: 0; }
}

/* Data packets */
@media (prefers-reduced-motion: no-preference) {
  .pkt-1 { animation: pkt-travel 2.6s linear infinite; }
  .pkt-2 { animation: pkt-travel 2.6s linear infinite 1.1s; }
  .pkt-3 { animation: pkt-travel 2.6s linear infinite 0.5s; }
  .pkt-4 { animation: pkt-travel 1.8s linear infinite 0.9s; }
  .pkt-5 { animation: pkt-travel 2.6s linear infinite 1.7s; }
  .pkt-6 { animation: pkt-travel 3.2s linear infinite 0.3s; }
}
/* dashoffset = line_length + 4 (packet size) traveling end-to-end */
@keyframes pkt-travel {
  0%   { stroke-dashoffset: 110; }
  100% { stroke-dashoffset: -110; }
}

/* ─────────────────── REDUCED MOTION FALLBACK ─────────────────── */
@media (prefers-reduced-motion: reduce) {
  .reel-1, .reel-2, .reel-3,
  .orb, .py-scroll, .pkt, .hub-ring { animation: none; }
}

/* ─────────────────── HOVER LIFT ─────────────────── */
.cap-card {
  transition: transform 0.3s ease, border-color 0.3s ease;
}
@media (prefers-reduced-motion: no-preference) {
  .cap-card:hover {
    transform: translateY(-3px);
  }
}
</style>
