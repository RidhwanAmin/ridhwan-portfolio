---
/**
 * CredentialPill.astro — small monochrome badge for credentials, awards, and
 * affiliations in the About section (MEXT, IEEE, etc.).
 *
 * Zero-Hue: no colored variants. Depth comes from the surface/border tokens.
 * The `variant` prop is accepted for backward compatibility but no longer
 * changes the color.
 */
import { Icon } from "astro-icon/components";

export interface Props {
  label: string;
  /** Optional Lucide icon name e.g. "lucide:award" */
  icon?: string;
  /** Deprecated; retained for compatibility. Has no visual effect. */
  variant?: "teal" | "amber" | "muted";
}

const { label, icon } = Astro.props;
---

<span
  class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-1 text-xs font-medium text-[var(--color-text-primary)] transition-colors duration-150 hover:border-[var(--color-border-strong)] hover:bg-[var(--color-surface-hover)]"
>
  {
    icon && (
      <Icon
        name={icon}
        class="h-3 w-3 shrink-0 text-[var(--color-text-secondary)]"
        aria-hidden="true"
      />
    )
  }
  {label}
</span>
