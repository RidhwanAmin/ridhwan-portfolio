---
/**
 * CredentialPill.astro — Agent A owns this file. Task A9.
 *
 * Small pill/badge component used in the About section to display
 * credentials, awards, and affiliations (MEXT, IEEE, etc.).
 */
import { Icon } from "astro-icon/components";

export interface Props {
  label: string;
  /** Optional Lucide icon name e.g. "lucide:award" */
  icon?: string;
  /** "teal" | "amber" | "muted" */
  variant?: "teal" | "amber" | "muted";
}

const { label, icon, variant = "muted" } = Astro.props;

const variantClasses = {
  teal: "border-[var(--color-teal-muted)] bg-[var(--color-teal-muted)] text-[var(--color-teal)]",
  amber:
    "border-[var(--color-amber-muted)] bg-[var(--color-amber-muted)] text-[var(--color-amber)]",
  muted:
    "border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text-secondary)]",
};
---

<span
  class:list={[
    "inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-medium",
    variantClasses[variant],
  ]}
>
  {icon && <Icon name={icon} class="h-3 w-3 shrink-0" aria-hidden="true" />}
  {label}
</span>
