---
/**
 * ContactSection.astro — Agent A owns this file. Task A14.
 *
 * Two-column contact section:
 * - Left column: contact info + social links + Cal.com embed placeholder
 * - Right column: contact form (POSTs to /api/contact per cross-agent contract)
 *
 * Form contract (from CLAUDE.md):
 *   POST /api/contact with {name, email, message}
 *   Response: {success: boolean, error?: string}
 *
 * Agent B (B7) implements the /api/contact endpoint.
 * This component handles the client-side form logic only.
 */
import { Icon } from "astro-icon/components";
import { SOCIAL_LINKS } from "@/config";
---

<section
  id="contact"
  class="py-24"
  aria-labelledby="contact-heading"
  data-reveal="section"
>
  <div class="app-layout">
    <!-- Section header -->
    <div class="mb-12 flex flex-col gap-2" data-reveal="fade-up">
      <span class="font-mono text-sm text-[var(--color-text-secondary)]">
        <span class="opacity-50">//</span> contact
      </span>
      <h2
        id="contact-heading"
        class="font-display text-3xl font-bold tracking-tight text-[var(--color-text-primary)] text-balance sm:text-4xl"
      >
        Let's work together
      </h2>
      <p class="mt-2 max-w-xl text-[var(--color-text-secondary)]">
        Whether you need ML infrastructure, a research collaboration, or just
        want to talk about seismic imaging, I'm reachable.
      </p>
      <div class="mt-4">
        <a
          href="/services"
          class="group inline-flex items-center gap-2 border border-[var(--color-border-strong)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text-primary)] transition-all duration-200 active:scale-[0.98] hover:border-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-text-primary)]"
        >
          View services and pricing
          <Icon
            name="lucide:arrow-right"
            class="h-4 w-4 transition-transform duration-150 group-hover:translate-x-0.5"
            aria-hidden="true"
          />
        </a>
      </div>
    </div>

    <div class="grid gap-12 md:grid-cols-2" data-reveal="fade-up">
      <!-- Left column: contact info + Cal.com placeholder -->
      <div class="flex flex-col gap-8">
        <!-- Contact info list -->
        <ul class="space-y-4" aria-label="Contact information">
          <li class="flex items-start gap-3">
            <span
              class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-teal-muted)]"
            >
              <Icon
                name="lucide:mail"
                class="h-4 w-4 text-[var(--color-teal)]"
                aria-hidden="true"
              />
            </span>
            <div>
              <p class="text-xs text-[var(--color-text-muted)]">Email</p>
              <a
                href={SOCIAL_LINKS.email}
                class="text-sm text-[var(--color-text-primary)] transition-colors duration-150 hover:text-[var(--color-teal)]"
              >
                ridhwanamin97@gmail.com
              </a>
            </div>
          </li>

          <li class="flex items-start gap-3">
            <span
              class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-teal-muted)]"
            >
              <Icon
                name="lucide:linkedin"
                class="h-4 w-4 text-[var(--color-teal)]"
                aria-hidden="true"
              />
            </span>
            <div>
              <p class="text-xs text-[var(--color-text-muted)]">LinkedIn</p>
              <a
                href={SOCIAL_LINKS.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-[var(--color-text-primary)] transition-colors duration-150 hover:text-[var(--color-teal)]"
                aria-label="LinkedIn profile (opens in new tab)"
              >
                linkedin.com/in/ridhwanamin
              </a>
            </div>
          </li>

          <li class="flex items-start gap-3">
            <span
              class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-teal-muted)]"
            >
              <Icon
                name="lucide:github"
                class="h-4 w-4 text-[var(--color-teal)]"
                aria-hidden="true"
              />
            </span>
            <div>
              <p class="text-xs text-[var(--color-text-muted)]">GitHub</p>
              <a
                href={SOCIAL_LINKS.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-[var(--color-text-primary)] transition-colors duration-150 hover:text-[var(--color-teal)]"
                aria-label="GitHub profile (opens in new tab)"
              >
                github.com/RidhwanAmin
              </a>
            </div>
          </li>
        </ul>

        <!-- Cal.com embed placeholder -->
        <!-- Agent D / future task: replace with real Cal.com embed script -->
        <div
          class="rounded-xl border border-dashed border-[var(--color-border-strong)] bg-[var(--color-surface)] p-6 text-center"
          role="complementary"
          aria-label="Calendar booking placeholder"
        >
          <Icon
            name="lucide:calendar"
            class="mx-auto mb-3 h-8 w-8 text-[var(--color-text-muted)]"
            aria-hidden="true"
          />
          <p class="text-sm font-medium text-[var(--color-text-secondary)]">
            Schedule a call
          </p>
          <p class="mt-1 text-xs text-[var(--color-text-muted)]">
            Cal.com booking widget, coming soon.
          </p>
          <a
            href="mailto:ridhwanamin97@gmail.com?subject=Consulting%20Enquiry"
            class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-[var(--color-teal)] hover:underline"
            aria-label="Email to schedule a call"
          >
            Email to schedule
            <Icon
              name="lucide:arrow-right"
              class="h-3 w-3"
              aria-hidden="true"
            />
          </a>
        </div>
      </div>

      <!-- Right column: contact form -->
      <div>
        <form
          id="contact-form"
          novalidate
          aria-label="Contact form"
          class="flex flex-col gap-5"
        >
          <!-- Name -->
          <div class="flex flex-col gap-1.5">
            <label
              for="contact-name"
              class="text-sm font-medium text-[var(--color-text-primary)]"
            >
              Name <span class="text-[var(--color-teal)]" aria-hidden="true"
                >*</span
              >
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              aria-invalid="false"
              aria-describedby="contact-name-error"
              placeholder="Your full name"
              class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] transition-colors duration-150 outline-none focus:border-[var(--color-teal)] focus:ring-1 focus:ring-[var(--color-teal)] aria-[invalid=true]:border-[var(--color-text-primary)] aria-[invalid=true]:ring-1 aria-[invalid=true]:ring-[var(--color-text-primary)]"
            />
            <p
              id="contact-name-error"
              class="hidden text-xs font-medium text-[var(--color-text-primary)]"
            >
            </p>
          </div>

          <!-- Email -->
          <div class="flex flex-col gap-1.5">
            <label
              for="contact-email"
              class="text-sm font-medium text-[var(--color-text-primary)]"
            >
              Email <span class="text-[var(--color-teal)]" aria-hidden="true"
                >*</span
              >
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              aria-invalid="false"
              aria-describedby="contact-email-error"
              placeholder="you@company.com"
              class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] transition-colors duration-150 outline-none focus:border-[var(--color-teal)] focus:ring-1 focus:ring-[var(--color-teal)] aria-[invalid=true]:border-[var(--color-text-primary)] aria-[invalid=true]:ring-1 aria-[invalid=true]:ring-[var(--color-text-primary)]"
            />
            <p
              id="contact-email-error"
              class="hidden text-xs font-medium text-[var(--color-text-primary)]"
            >
            </p>
          </div>

          <!-- Message -->
          <div class="flex flex-col gap-1.5">
            <label
              for="contact-message"
              class="text-sm font-medium text-[var(--color-text-primary)]"
            >
              Message <span class="text-[var(--color-teal)]" aria-hidden="true"
                >*</span
              >
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows={5}
              aria-invalid="false"
              aria-describedby="contact-message-error"
              placeholder="Tell me about your project or question…"
              class="resize-none rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] transition-colors duration-150 outline-none focus:border-[var(--color-teal)] focus:ring-1 focus:ring-[var(--color-teal)] aria-[invalid=true]:border-[var(--color-text-primary)] aria-[invalid=true]:ring-1 aria-[invalid=true]:ring-[var(--color-text-primary)]"
            ></textarea>
            <p
              id="contact-message-error"
              class="hidden text-xs font-medium text-[var(--color-text-primary)]"
            >
            </p>
          </div>

          <!-- Status message (hidden until submit) -->
          <p
            id="contact-status"
            role="status"
            aria-live="polite"
            class="hidden text-sm"
          >
          </p>

          <!-- Submit button -->
          <button
            id="contact-submit"
            type="submit"
            class="inline-flex items-center justify-center gap-2 border border-[var(--color-text-primary)] bg-[var(--color-text-primary)] px-6 py-3 text-sm font-semibold text-[var(--color-bg)] transition-all duration-200 active:scale-[0.98] hover:bg-transparent hover:text-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-text-primary)] disabled:cursor-not-allowed disabled:opacity-50 disabled:active:scale-100"
          >
            <Icon name="lucide:send" class="h-4 w-4" aria-hidden="true" />
            Send message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  /**
   * Contact form — sends via EmailJS (client-side, no server).
   *
   * Env vars (all PUBLIC_* so they’re inlined into the client bundle):
   *   PUBLIC_EMAILJS_SERVICE_ID    (default: service_7can0am)
   *   PUBLIC_EMAILJS_TEMPLATE_ID   — from EmailJS dashboard
   *   PUBLIC_EMAILJS_PUBLIC_KEY    — from EmailJS → Account → API Keys
   *
   * Template variables sent (must match template_v9lpz0q in the EmailJS dashboard):
   *   {{first_name}}, {{last_name}}, {{user_email}}, {{message}}
   *   The template's "To Email" field is bound to {{user_email}}, so that param
   *   must always be supplied or EmailJS returns "The recipient's address is empty".
   */
  import emailjs from "@emailjs/browser";

  const SERVICE_ID =
    import.meta.env.PUBLIC_EMAILJS_SERVICE_ID || "service_7can0am";
  const TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
  const PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;

  type FieldName = "name" | "email" | "message";

  function setupContactForm() {
    const form = document.getElementById(
      "contact-form"
    ) as HTMLFormElement | null;
    if (!form) return;

    const submitBtn = document.getElementById(
      "contact-submit"
    ) as HTMLButtonElement;
    const statusEl = document.getElementById(
      "contact-status"
    ) as HTMLParagraphElement;

    // Field-level validation: each field validates on blur and on submit, marks
    // itself with aria-invalid + an inline message, and clears as soon as it's
    // valid again. Entered values are never wiped on a validation failure.
    const fields: Record<
      FieldName,
      {
        input: HTMLInputElement | HTMLTextAreaElement;
        error: HTMLElement;
        validate: (v: string) => string | null;
      }
    > = {
      name: {
        input: document.getElementById("contact-name") as HTMLInputElement,
        error: document.getElementById("contact-name-error") as HTMLElement,
        validate: v => (v.trim() ? null : "Enter your name."),
      },
      email: {
        input: document.getElementById("contact-email") as HTMLInputElement,
        error: document.getElementById("contact-email-error") as HTMLElement,
        validate: v =>
          !v.trim()
            ? "Enter your email."
            : /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim())
              ? null
              : "Enter a valid email, e.g. you@company.com.",
      },
      message: {
        input: document.getElementById(
          "contact-message"
        ) as HTMLTextAreaElement,
        error: document.getElementById("contact-message-error") as HTMLElement,
        validate: v => (v.trim().length >= 2 ? null : "Add a short message."),
      },
    };

    function setFieldError(name: FieldName, msg: string | null) {
      const f = fields[name];
      if (msg) {
        f.input.setAttribute("aria-invalid", "true");
        f.error.textContent = `! ${msg}`;
        f.error.classList.remove("hidden");
      } else {
        f.input.setAttribute("aria-invalid", "false");
        f.error.textContent = "";
        f.error.classList.add("hidden");
      }
    }

    function validateField(name: FieldName): boolean {
      const msg = fields[name].validate(fields[name].input.value);
      setFieldError(name, msg);
      return !msg;
    }

    const order: FieldName[] = ["name", "email", "message"];
    order.forEach(name => {
      const input = fields[name].input;
      input.addEventListener("blur", () => validateField(name));
      input.addEventListener("input", () => {
        if (input.getAttribute("aria-invalid") === "true") validateField(name);
      });
    });

    function showStatus(message: string, isError: boolean) {
      // Zero-Hue: monochrome status. Meaning is carried by the wording, the
      // leading marker, and the aria-live announcement, never by color alone.
      statusEl.textContent = `${isError ? "!" : "→"}  ${message}`;
      statusEl.className =
        "text-sm font-medium text-[var(--color-text-primary)]";
      statusEl.classList.remove("hidden");
    }

    form.addEventListener("submit", async e => {
      e.preventDefault();

      // Validate every field; focus the first invalid one and stop.
      let firstInvalid: FieldName | null = null;
      for (const name of order) {
        if (!validateField(name) && !firstInvalid) firstInvalid = name;
      }
      if (firstInvalid) {
        statusEl.classList.add("hidden");
        fields[firstInvalid].input.focus();
        return;
      }

      // Config sanity check — keys must be present at build time
      if (!TEMPLATE_ID || !PUBLIC_KEY) {
        // eslint-disable-next-line no-console
        console.error(
          "[contact] EmailJS is not configured. Set PUBLIC_EMAILJS_TEMPLATE_ID and PUBLIC_EMAILJS_PUBLIC_KEY in .env."
        );
        showStatus(
          "Email service is not configured. Please email me directly.",
          true
        );
        return;
      }

      const sendIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>`;
      const spinnerIcon = `<svg class="animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>`;
      const checkIcon = `<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`;

      submitBtn.disabled = true;
      submitBtn.innerHTML = `${spinnerIcon} Sending…`;
      statusEl.classList.add("hidden");

      try {
        // Map the form's single "name" field to the template's first/last_name,
        // and supply user_email — the template binds its "To Email" to {{user_email}}.
        const fullName = fields.name.input.value.trim();
        const [firstName, ...rest] = fullName.split(/\s+/);
        const lastName = rest.join(" ");

        await emailjs.send(
          SERVICE_ID,
          TEMPLATE_ID,
          {
            first_name: firstName,
            last_name: lastName,
            user_email: fields.email.input.value.trim(),
            message: fields.message.input.value.trim(),
          },
          { publicKey: PUBLIC_KEY }
        );

        showStatus(
          "Message sent! I'll get back to you within 24 hours.",
          false
        );
        form.reset();
        order.forEach(name => setFieldError(name, null));
        // Brief success state on the button, then restore.
        submitBtn.innerHTML = `${checkIcon} Sent`;
        window.setTimeout(() => {
          submitBtn.innerHTML = `${sendIcon} Send message`;
        }, 1800);
      } catch (err) {
        // eslint-disable-next-line no-console
        console.error("[contact] EmailJS error:", err);
        const msg =
          (err as { text?: string; message?: string })?.text ||
          (err as { text?: string; message?: string })?.message ||
          "Failed to send. Please try again or email me directly.";
        showStatus(msg, true);
        submitBtn.innerHTML = `${sendIcon} Send message`;
      } finally {
        submitBtn.disabled = false;
      }
    });
  }

  setupContactForm();
  document.addEventListener("astro:after-swap", setupContactForm);
</script>
