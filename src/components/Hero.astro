---
/**
 * Hero.astro — Black & White Minimalist redesign.
 *
 * Layout: asymmetric 2-column (60/40)
 *   Left: Sora display heading, monospace role label, description, high-contrast CTAs
 *   Right: B&W heatmap grid — gradient from sparse (top-left) → dense (bottom-right)
 *          evoking model output / data density; pure B&W, CSS-animated
 *
 * No decorative backgrounds — white or black only.
 * Animations: staggered cell reveal (CSS), GSAP entrance handled in index.astro (A15).
 * All motion respects prefers-reduced-motion.
 */
import { Icon } from "astro-icon/components";
import { SITE } from "@/config";

// Generate a 14×9 B&W heatmap — density increases from top-left to bottom-right
// (sparse → dense visual narrative: noise → signal)
const COLS = 14;
const ROWS = 9;
const heatCells = Array.from({ length: COLS * ROWS }, (_, i) => {
  const col = i % COLS;
  const row = Math.floor(i / COLS);
  // Gradient: top-left sparse, bottom-right dense
  const base = (col / (COLS - 1)) * 0.55 + (row / (ROWS - 1)) * 0.35;
  // Deterministic noise to avoid uniform bands
  const noise = (((i * 2654435761 + 1013904223) >>> 0) % 1000) / 1000 * 0.18;
  return Math.min(1, base + noise).toFixed(2);
});
---

<section
  id="hero"
  class="relative flex min-h-[100svh] items-center overflow-hidden"
  aria-label="Hero — introduction"
>
  <!-- Content -->
  <div class="relative z-10 app-layout w-full py-24">
    <div class="hero-grid grid items-center gap-16">

      <!-- LEFT: text content -->
      <div class="flex flex-col gap-7">

        <!-- Monospace label strip -->
        <div class="hero-meta flex flex-wrap items-center gap-x-5 gap-y-2">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-text-muted)]">
            AI / ML Researcher
          </span>
          <span class="h-px w-8 bg-[var(--color-text-muted)]" aria-hidden="true"></span>
          <span class="inline-flex items-center gap-1.5">
            <span
              class="availability-dot h-1.5 w-1.5 rounded-full bg-[var(--color-text-primary)]"
              aria-hidden="true"
            ></span>
            <span class="font-mono text-xs uppercase tracking-[0.12em] text-[var(--color-text-secondary)]">
              Available — 2 slots
            </span>
          </span>
          <span class="font-mono text-xs uppercase tracking-[0.12em] text-[var(--color-text-muted)]">
            UTC+8
          </span>
        </div>

        <!-- Name — Sora display font, max contrast -->
        <h1
          id="hero-headline"
          class="hero-headline font-display text-[clamp(2.8rem,7vw,5.5rem)] leading-[0.95] font-bold tracking-tight text-[var(--color-text-primary)]"
        >
          {SITE.author}
        </h1>

        <!-- Thin rule under name -->
        <div class="hero-rule h-px w-16 bg-[var(--color-text-primary)]" aria-hidden="true"></div>

        <!-- Description -->
        <p
          id="hero-desc"
          class="hero-desc max-w-md text-base leading-relaxed text-[var(--color-text-secondary)]"
        >
          I build seismic inpainting models, anomaly detection systems, and
          hybrid RAG pipelines at UTP. I consult with teams that need
          production-ready ML infrastructure.
        </p>

        <!-- CTAs — high contrast, square-cornered -->
        <div id="hero-ctas" class="hero-ctas flex flex-wrap gap-3">
          <a
            href="#projects"
            data-scroll-to="projects"
            class="cta-primary inline-flex items-center gap-2.5 border border-[var(--color-text-primary)] bg-[var(--color-text-primary)] px-6 py-3 text-sm font-semibold text-[var(--color-bg)] transition-all duration-200 hover:bg-transparent hover:text-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-text-primary)]"
            aria-label="View my projects"
          >
            View Projects
            <Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
          </a>
          <a
            href="#contact"
            data-scroll-to="contact"
            class="inline-flex items-center gap-2.5 border border-[var(--color-border-strong)] px-6 py-3 text-sm font-semibold text-[var(--color-text-primary)] transition-all duration-200 hover:border-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-text-primary)]"
            aria-label="Get in touch"
          >
            Get in Touch
            <Icon name="lucide:mail" class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>

        <!-- Location -->
        <div class="flex items-center gap-2 opacity-60">
          <Icon name="lucide:map-pin" class="h-3.5 w-3.5 text-[var(--color-text-muted)]" aria-hidden="true" />
          <span class="font-mono text-xs text-[var(--color-text-muted)]">Seri Iskandar, Malaysia</span>
        </div>

      </div><!-- /left -->

      <!-- RIGHT: B&W heatmap grid — data density visualization -->
      <div aria-hidden="true">
        <div class="heatmap-wrapper">
          <p class="heatmap-label">model output distribution</p>
          <div
            class="heatmap-grid"
            style={`grid-template-columns: repeat(${COLS}, 1fr);`}
          >
            {heatCells.map((opacity, i) => (
              <div
                class="heatmap-cell"
                style={`opacity: ${opacity}; animation-delay: ${(i % COLS) * 35}ms`}
              ></div>
            ))}
          </div>
          <div class="heatmap-axis">
            <span>low density</span>
            <div class="heatmap-scale" aria-hidden="true"></div>
            <span>high density</span>
          </div>
        </div>
      </div><!-- /right -->

    </div><!-- /hero-grid -->

    <!-- Scroll indicator -->
    <div
      id="scroll-indicator"
      class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2"
      aria-hidden="true"
    >
      <Icon
        name="lucide:chevrons-down"
        class="h-5 w-5 animate-bounce text-[var(--color-text-muted)]"
        aria-hidden="true"
      />
    </div>

  </div>
</section>

<style>
  /* ===== Two-column grid: 60/40 on lg+ ===== */
  .hero-grid {
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 3fr 2fr;
    }
  }

  /* ===== Availability pulse dot ===== */
  .availability-dot {
    animation: pulse-dot 3s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.2; }
  }

  /* ===== Heatmap panel ===== */
  .heatmap-wrapper {
    width: 100%;
    max-width: 380px;
    margin: 0 auto;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-text-primary);
  }

  .heatmap-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .heatmap-grid {
    display: grid;
    gap: 3px;
    width: 100%;
  }

  .heatmap-cell {
    aspect-ratio: 1;
    background-color: var(--color-text-primary);
    border-radius: 1px;
    animation: cell-reveal 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
    transform-origin: center;
  }

  @keyframes cell-reveal {
    from {
      transform: scale(0);
      opacity: 0;
    }
    to {
      transform: scale(1);
      /* opacity: as set by inline style */
    }
  }

  /* Scale to full opacity on reveal, then settle to cell's value */
  /* We animate opacity separately with a second pass */
  .heatmap-cell {
    animation:
      cell-reveal 0.35s cubic-bezier(0.16, 1, 0.3, 1) both,
      cell-settle 0.6s ease-out both;
  }
  /* cell-settle: opacity flashes to 1 then settles to inline value */
  @keyframes cell-settle {
    0%   { filter: brightness(2); }
    100% { filter: brightness(1); }
  }

  .heatmap-axis {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
  }

  .heatmap-scale {
    flex: 1;
    height: 2px;
    background: linear-gradient(
      to right,
      rgba(128, 128, 128, 0.15),
      var(--color-text-primary)
    );
  }

  /* ===== Scroll indicator ===== */
  @media (prefers-reduced-motion: reduce) {
    .availability-dot,
    .heatmap-cell {
      animation: none;
    }
    .scroll-indicator {
      display: none;
    }
  }
</style>

<script>
  function setupHeroScrollLinks() {
    document.querySelectorAll("#hero [data-scroll-to]").forEach(el => {
      el.addEventListener("click", e => {
        const id = (el as HTMLElement).dataset.scrollTo;
        if (!id) return;
        const target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        const lenis = (window as any).__lenis;
        if (lenis) {
          lenis.scrollTo(target, { offset: -64, duration: 1.2 });
        } else {
          target.scrollIntoView({ behavior: "smooth" });
        }
      });
    });
  }

  setupHeroScrollLinks();
  document.addEventListener("astro:after-swap", setupHeroScrollLinks);
</script>
