---
/**
 * Hero.astro — Agent A owns this file. Task A6.
 *
 * Full-viewport hero with animated CSS gradient mesh background.
 * Two CTAs: scroll to #projects, scroll to #contact.
 *
 * Animation rule: only transform + opacity. prefers-reduced-motion disables all motion.
 * No raster images — CSS-only decorative background.
 */
import { Icon } from "astro-icon/components";
import { SITE } from "@/config";
---

<section
  id="hero"
  class="relative flex min-h-[100svh] items-center justify-center overflow-hidden"
  aria-label="Hero — introduction"
>
  <!-- Animated CSS gradient mesh background (CSS-only, no raster) -->
  <div class="mesh-bg" aria-hidden="true"></div>

  <!-- Noise overlay for texture -->
  <div class="noise-overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 app-layout py-24 text-center">
    <!-- Availability badge -->
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-teal-muted)] bg-[var(--color-teal-muted)] px-4 py-1.5"
    >
      <span
        class="availability-dot h-2 w-2 rounded-full bg-[var(--color-teal)]"
        aria-hidden="true"></span>
      <span class="text-xs font-medium text-[var(--color-teal)]"
        >Available for consulting — 2 slots open</span
      >
    </div>

    <!-- Name + title -->
    <h1
      id="hero-headline"
      class="hero-headline mb-4 text-4xl leading-tight font-bold tracking-tight text-[var(--color-text-primary)] sm:text-5xl md:text-6xl lg:text-7xl"
    >
      {SITE.author}
    </h1>

    <p
      id="hero-sub"
      class="hero-sub mx-auto mb-4 max-w-xl text-lg font-medium text-[var(--color-teal)] sm:text-xl"
    >
      AI/ML Researcher &amp; Engineer
    </p>

    <p
      id="hero-desc"
      class="hero-desc mx-auto mb-10 max-w-2xl text-base leading-relaxed text-[var(--color-text-secondary)] sm:text-lg"
    >
      I build seismic inpainting models, anomaly detection systems, and hybrid
      RAG pipelines at UTP. I also consult with teams that need production-ready
      ML infrastructure.
    </p>

    <!-- Dual CTAs -->
    <div
      id="hero-ctas"
      class="hero-ctas flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <a
        href="#projects"
        data-scroll-to="projects"
        class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-teal)] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-teal-500/20 transition-all duration-200 hover:opacity-90 hover:shadow-teal-500/30 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
        aria-label="View my projects"
      >
        View Projects
        <Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
      </a>

      <a
        href="#contact"
        data-scroll-to="contact"
        class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border-strong)] bg-[var(--color-surface)] px-6 py-3 text-sm font-semibold text-[var(--color-text-primary)] transition-all duration-200 hover:border-[var(--color-teal)] hover:bg-[var(--color-surface-hover)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
        aria-label="Get in touch"
      >
        Get in Touch
        <Icon name="lucide:mail" class="h-4 w-4" aria-hidden="true" />
      </a>
    </div>

    <!-- Scroll indicator -->
    <div
      id="scroll-indicator"
      class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2"
      aria-hidden="true"
    >
      <Icon
        name="lucide:chevrons-down"
        class="h-5 w-5 animate-bounce text-[var(--color-text-muted)]"
        aria-hidden="true"
      />
    </div>
  </div>
</section>

<style>
  /* ===== Animated gradient mesh — CSS only, no images ===== */
  .mesh-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 80% 60% at 20% 30%,
        rgba(29, 158, 117, 0.12) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse 60% 50% at 80% 70%,
        rgba(239, 159, 39, 0.08) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse 100% 80% at 50% 50%,
        rgba(29, 158, 117, 0.04) 0%,
        transparent 70%
      ),
      var(--color-bg);
    animation: mesh-drift 20s ease-in-out infinite alternate;
  }

  @media (prefers-reduced-motion: reduce) {
    .mesh-bg {
      animation: none;
    }
  }

  @keyframes mesh-drift {
    0% {
      background-position:
        0% 0%,
        100% 100%,
        50% 50%;
    }
    33% {
      background-position:
        20% 10%,
        80% 80%,
        60% 40%;
    }
    66% {
      background-position:
        10% 20%,
        90% 70%,
        40% 60%;
    }
    100% {
      background-position:
        5% 15%,
        85% 85%,
        55% 45%;
    }
  }

  /* Noise overlay for texture — SVG data URI */
  .noise-overlay {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    pointer-events: none;
  }

  /* Availability dot pulse */
  .availability-dot {
    animation: pulse-dot 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .availability-dot {
      animation: none;
    }
    .scroll-indicator {
      display: none;
    }
  }

  /* Initial state for GSAP ScrollReveal (A15 sets these via JS) */
  /* Elements start visible by default — GSAP A15 will set opacity:0 translateY:20px */
</style>

<script>
  /**
   * Hero scroll-to handlers.
   * The main scroll-to logic lives in Nav.astro's setupSectionScroll(),
   * but hero CTAs also have data-scroll-to so they're caught by the same handler.
   * This script ensures they work even if Nav hasn't run yet (e.g., direct page load).
   */
  function setupHeroScrollLinks() {
    document.querySelectorAll("#hero [data-scroll-to]").forEach(el => {
      el.addEventListener("click", e => {
        const id = (el as HTMLElement).dataset.scrollTo;
        if (!id) return;
        const target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        const lenis = (window as any).__lenis;
        if (lenis) {
          lenis.scrollTo(target, { offset: -64, duration: 1.2 });
        } else {
          target.scrollIntoView({ behavior: "smooth" });
        }
      });
    });
  }

  setupHeroScrollLinks();
  document.addEventListener("astro:after-swap", setupHeroScrollLinks);
</script>
