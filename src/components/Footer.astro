---
/**
 * Footer.astro — Three-column footer for ridhwan.dev
 */
import { Icon } from "astro-icon/components";
import { SITE, SOCIAL_LINKS, NAV_LINKS } from "@/config";

const year = new Date().getFullYear();
---

<footer
  class="border-t border-[var(--color-border)] bg-[var(--color-bg)]"
  aria-label="Site footer"
>
  <div class="app-layout py-12">
    <div class="grid gap-10 sm:grid-cols-3 sm:gap-8">
      <!-- Col 1: Wordmark + tagline -->
      <div class="flex flex-col gap-3">
        <a
          href="/"
          class="inline-flex items-center font-mono text-sm font-bold tracking-widest uppercase text-[var(--color-text-primary)] transition-opacity hover:opacity-80"
          aria-label={`${SITE.author} — home`}
        >
          <span class="text-[var(--color-teal)]">R.</span>
          <span class="ml-1">AMIN</span>
        </a>
        <p class="max-w-[220px] text-sm leading-relaxed text-[var(--color-text-secondary)]">
          AI/ML researcher at UTP. Building models at the intersection of deep
          learning and geophysics.
        </p>
      </div>

      <!-- Col 2: Nav links -->
      <nav aria-label="Footer navigation">
        <p class="mb-3 font-mono text-[0.65rem] font-bold uppercase tracking-widest text-[var(--color-text-muted)]">
          Navigation
        </p>
        <ul class="flex flex-col gap-2" role="list">
          {NAV_LINKS.map(link => (
            <li role="listitem">
              <a
                href={link.href}
                class="text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Col 3: Social links -->
      <div>
        <p class="mb-3 font-mono text-[0.65rem] font-bold uppercase tracking-widest text-[var(--color-text-muted)]">
          Connect
        </p>
        <ul class="flex flex-col gap-2.5" role="list">
          <li role="listitem">
            <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
              aria-label="GitHub (opens in new tab)">
              <Icon name="lucide:github" class="h-4 w-4" aria-hidden="true" />GitHub
            </a>
          </li>
          <li role="listitem">
            <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
              aria-label="LinkedIn (opens in new tab)">
              <Icon name="lucide:linkedin" class="h-4 w-4" aria-hidden="true" />LinkedIn
            </a>
          </li>
          <li role="listitem">
            <a href={SOCIAL_LINKS.email}
              class="inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
              aria-label="Send email">
              <Icon name="lucide:mail" class="h-4 w-4" aria-hidden="true" />Email
            </a>
          </li>
          <li role="listitem">
            <a href={SOCIAL_LINKS.substack} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-[var(--color-text-secondary)] transition-colors hover:text-[var(--color-substack)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-teal)]"
              aria-label="Substack newsletter (opens in new tab)">
              <Icon name="lucide:pen-line" class="h-4 w-4" aria-hidden="true" />Substack
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[var(--color-border)]">
    <div class="app-layout flex flex-col items-center justify-between gap-2 py-4 sm:flex-row">
      <p class="font-mono text-[0.65rem] text-[var(--color-text-muted)]">
        &copy; {year} Ridhwan Amin. All rights reserved.
      </p>
      <p class="font-mono text-[0.65rem] text-[var(--color-text-muted)]">
        Built with
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer"
          class="text-[var(--color-text-secondary)] underline decoration-dashed underline-offset-2 hover:text-[var(--color-text-primary)]"
          aria-label="Astro (opens in new tab)">Astro</a>
        &amp;
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer"
          class="text-[var(--color-text-secondary)] underline decoration-dashed underline-offset-2 hover:text-[var(--color-text-primary)]"
          aria-label="Tailwind CSS (opens in new tab)">Tailwind CSS</a>
      </p>
    </div>
  </div>
</footer>
